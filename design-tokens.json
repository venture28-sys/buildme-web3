{
  "name": "Build Me Design System",
  "version": "1.0.0",
  "color": {
    "primary": { "value": "#F97316", "name": "Construction Orange" },
    "primary-600": { "value": "#EA6A0C" },
    "primary-700": { "value": "#C2560A" },
    "primary-100": { "value": "#FFE7D3" },
    "secondary": { "value": "#0F172A", "name": "Deep Navy" },
    "secondary-700": { "value": "#334155" },
    "secondary-800": { "value": "#1E293B" },
    "accent": { "value": "#0EA5E9", "name": "Sky Blue" },
    "success": { "value": "#16A34A" },
    "warning": { "value": "#F59E0B" },
    "danger": { "value": "#DC2626" },
    "neutral": { "value": "#64748B" },
    "neutral-scale": {
      "25": "#F8FAFC", "50": "#F1F5F9", "100": "#E2E8F0", "200": "#CBD5E1",
      "300": "#94A3B8", "400": "#64748B", "500": "#475569", "600": "#334155",
      "700": "#1E293B", "800": "#0F172A"
    },
    "dark": {
      "bg": "#0B1220", "surface": "#131C2E", "surface-2": "#1A2436",
      "border": "#26324A", "text": "#F1F5F9", "text-muted": "#8A99B3"
    }
  },
  "typography": {
    "fontFamily": {
      "display": "Poppins",
      "body": "Inter",
      "mono": "JetBrains Mono"
    },
    "weights": { "display": [600, 700], "body": [400, 500, 600], "mono": [400, 700] },
    "scale": {
      "h1": "56px", "h2": "40px", "h3": "28px", "h4": "22px", "h5": "18px",
      "body-lg": "18px", "body": "16px", "body-sm": "14px", "caption": "12px"
    }
  },
  "spacing": {
    "1": "4px", "2": "8px", "3": "12px", "4": "16px", "6": "24px",
    "8": "32px", "12": "48px", "16": "64px", "24": "96px"
  },
  "radius": {
    "default": "12px",
    "sm": "8px",
    "full": "999px"
  },
  "shadow": {
    "card": "0 4px 6px -1px rgba(15,23,42,0.10), 0 2px 4px -1px rgba(15,23,42,0.06)",
    "lift": "0 12px 24px -8px rgba(15,23,42,0.20), 0 4px 8px -2px rgba(15,23,42,0.08)"
  },
  "motion": {
    "duration": { "fast": "200ms", "base": "320ms", "slow": "500ms" },
    "easing": "cubic-bezier(0.4, 0, 0.2, 1)"
  },
  "components": {
    "button": {
      "radius": "12px",
      "paddingX": "24px",
      "paddingY": "12px",
      "font": "Inter SemiBold 600",
      "variants": {
        "primary": { "bg": "#F97316", "text": "#FFFFFF" },
        "secondary": { "bg": "#F1F5F9", "text": "#0F172A" },
        "outline": { "border": "#0F172A", "text": "#0F172A" },
        "danger": { "bg": "#DC2626", "text": "#FFFFFF" },
        "disabled": { "bg": "#E2E8F0", "text": "#94A3B8" }
      }
    },
    "input": {
      "radius": "12px",
      "border": "1px solid #CBD5E1",
      "focusBorder": "2px solid #F97316",
      "errorBorder": "#DC2626",
      "helperColor": "#64748B"
    },
    "card": {
      "radius": "12px",
      "shadow": "0 4px 6px -1px rgba(0,0,0,0.1), 0 2px 4px -1px rgba(0,0,0,0.06)",
      "border": "1px solid #E2E8F0",
      "paddingMin": "24px"
    }
  },
  "icons": {
    "library": "lucide-react",
    "defaultSize": 20,
    "stroke": 1.5,
    "color": "currentColor"
  }
}
